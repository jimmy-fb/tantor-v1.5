# Tantor-generated KRaft Kafka Server Configuration
# Role: {{ process_roles }}

node.id={{ node_id }}
process.roles={{ process_roles }}

controller.quorum.voters={{ quorum_voters }}

listeners={{ listeners }}
advertised.listeners={{ advertised_listeners }}
controller.listener.names=CONTROLLER
inter.broker.listener.name=PLAINTEXT
listener.security.protocol.map={{ listener_security_protocol_map | default("CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT") }}

{% if ssl_enabled %}
# Tantor-managed TLS. Keystore is PKCS12 (cert + key + chain), truststore
# is plain PEM (single CA cert) — Java's PKCS12 truststore semantics don't
# round-trip cleanly through the Python `cryptography` lib.
ssl.keystore.type=PKCS12
ssl.keystore.location={{ ssl_keystore_location }}
ssl.keystore.password={{ ssl_keystore_password }}
ssl.key.password={{ ssl_keystore_password }}
ssl.truststore.type=PEM
ssl.truststore.location={{ ssl_truststore_location }}
{% if mtls_required %}
# mTLS: every client must present a cert signed by the cluster CA.
ssl.client.auth=required
{% endif %}
# Map every cert DN to the ANONYMOUS principal so SSL/mTLS clients hit
# the same `super.users=User:ANONYMOUS` row Tantor sets up out of the
# box and `allow.everyone.if.no.acl.found=true` continues to apply.
# Tighten this rule (e.g. `RULE:^CN=(.*?),.*$/$1/`) once you start
# enforcing per-principal ACLs on the cluster.
ssl.principal.mapping.rules=RULE:^.*$/ANONYMOUS/,DEFAULT
{% endif %}

log.dirs={{ log_dirs }}

num.network.threads=3
num.io.threads=8
socket.send.buffer.bytes=102400
socket.receive.buffer.bytes=102400
# APB v1.4.3 #6 — raised from 100MB → 200MB. The customer hit
# `InvalidReceiveException: message size 369296129 exceeded ...104857600`
# repeatedly. 369296129 = 0x16030101 = the first 4 bytes of a TLS 1.x
# ClientHello — i.e. an SSL client is connecting to a PLAINTEXT
# listener and Kafka is reading the TLS handshake bytes as a Kafka
# frame length. 200MB still rejects truly malformed traffic but stops
# spamming the log every reconnect cycle. Real fix is to keep all
# producers/consumers on the SSL listener when ssl_enabled is on.
socket.request.max.bytes=209715200

num.partitions={{ num_partitions }}
default.replication.factor={{ replication_factor }}
min.insync.replicas={{ [replication_factor - 1, 1] | max }}

offsets.topic.replication.factor={{ replication_factor }}
transaction.state.log.replication.factor={{ replication_factor }}
transaction.state.log.min.isr={{ [replication_factor - 1, 1] | max }}

log.retention.hours=168
log.segment.bytes=1073741824
log.retention.check.interval.ms=300000

group.initial.rebalance.delay.ms=0

# Security: ACL authorizer (KRaft native)
authorizer.class.name=org.apache.kafka.metadata.authorizer.StandardAuthorizer
super.users=User:ANONYMOUS
allow.everyone.if.no.acl.found=true
