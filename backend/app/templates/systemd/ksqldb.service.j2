[Unit]
Description=ksqlDB Server
After=network.target kafka.service

[Service]
Type=simple
User=kafka
Group=kafka
Environment="JAVA_HOME={{ java_home }}"
Environment="KSQL_HEAP_OPTS={{ heap_opts | default('-Xmx512M -Xms512M') }}"
Environment="KSQL_LOG4J_OPTS=-Dlog4j.configuration=file:{{ ksqldb_home }}/etc/ksqldb/log4j-rolling.properties"
{% if jvm_performance_opts %}
Environment="KAFKA_JVM_PERFORMANCE_OPTS={{ jvm_performance_opts }}"
{% endif %}
{% if jmx_port %}
Environment="JMX_PORT={{ jmx_port }}"
{% endif %}
{% if gc_logging_enabled %}
Environment="KAFKA_GC_LOG_OPTS=-Xlog:gc*:file=/var/log/kafka/gc-ksqldb.log:time,level,tags:filecount=10,filesize=10M"
{% endif %}
ExecStartPre=/bin/bash -c 'test -x {{ java_home }}/bin/java || (echo "JAVA_HOME invalid: {{ java_home }}" && exit 1)'
ExecStart={{ ksqldb_home }}/bin/ksql-server-start {{ config_path }}
Restart=on-failure
RestartSec=10
TimeoutStopSec=60
LimitNOFILE=100000
{% if cpu_quota %}
CPUQuota={{ cpu_quota }}
{% endif %}
{% if memory_max %}
MemoryMax={{ memory_max }}
{% endif %}
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ksqldb

[Install]
WantedBy=multi-user.target
