---
# =============================================================================
# Tantor Kafka Deployment Playbook (Production-Ready)
# - Validates Java, discovers JAVA_HOME
# - Cleans stale services before deploying
# - Validates meta.properties node_id consistency
# - Health checks after each service start
# =============================================================================

- name: Prepare Kafka on all hosts
  hosts: all
  become: true
  tasks:
    - name: Gather OS facts
      setup:
        gather_subset:
          - '!all'
          - 'os_family'
          - 'distribution'
          - 'distribution_major_version'

    # ── Java Installation ──────────────────────────────────────────────
    - name: Install Java (Debian/Ubuntu)
      apt:
        name: openjdk-17-jre-headless
        state: present
        update_cache: true
      when: ansible_os_family == "Debian"

    - name: Install Java (RHEL/Rocky/CentOS)
      dnf:
        name: java-17-openjdk-headless
        state: present
      when: ansible_os_family == "RedHat"

    # ── Discover real JAVA_HOME (critical: don't trust env vars) ─────
    - name: Find java binary path
      command: which java
      register: java_which
      changed_when: false

    - name: Resolve java symlink to real path
      command: readlink -f {{ '{{' }} java_which.stdout {{ '}}' }}
      register: java_real
      changed_when: false

    - name: Set JAVA_HOME fact
      set_fact:
        discovered_java_home: "{{ '{{' }} java_real.stdout | regex_replace('/bin/java$', '') {{ '}}' }}"

    - name: Validate Java works
      command: "{{ '{{' }} discovered_java_home {{ '}}' }}/bin/java -version"
      register: java_ver
      changed_when: false
      failed_when: java_ver.rc != 0

    - name: Display Java info
      debug:
        msg: "JAVA_HOME={{ '{{' }} discovered_java_home {{ '}}' }} | {{ '{{' }} java_ver.stderr_lines[0] | default('unknown') {{ '}}' }}"

    - name: Fix /etc/profile.d/java.sh
      copy:
        content: |
          export JAVA_HOME={{ '{{' }} discovered_java_home {{ '}}' }}
          export PATH=$JAVA_HOME/bin:$PATH
        dest: /etc/profile.d/java.sh
        mode: "0644"

    # ── Cleanup stale Kafka services ─────────────────────────────────
    # APB v1.2.0 #5 — DO NOT wipe every kafka*.service unit. The previous
    # logic blew away neighboring Tantor clusters' units. Stop ONLY this
    # cluster's unit (idempotent: ignore-error if it doesn't exist yet).
    # APB v1.4.3 #2 — first time a cluster deploys this unit doesn't
    # exist yet, so `systemctl stop` would print a yellow warning.
    # Probe with `systemctl list-unit-files` first so we only call
    # stop when the unit really exists, keeping the deploy log clean.
    - name: Detect existing Kafka unit
      shell: "systemctl list-unit-files --no-legend --no-pager 2>/dev/null | awk '{print $1}' | grep -Fxq {{ kafka_unit_name }}"
      register: kafka_unit_present
      failed_when: false
      changed_when: false

    - name: Stop existing instance of this cluster's Kafka unit (if it exists)
      systemd:
        name: "{{ kafka_unit_name }}"
        state: stopped
      when: kafka_unit_present.rc == 0

    - name: Reload systemd after cleanup
      systemd:
        daemon_reload: true

    # ── Create user and directories ──────────────────────────────────
    - name: Create kafka group
      group:
        name: kafka
        system: true

    - name: Create kafka user
      user:
        name: kafka
        group: kafka
        system: true
        shell: /bin/false
        create_home: true
        home: /home/kafka

    - name: Create required directories
      file:
        path: "{{ '{{' }} item {{ '}}' }}"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"
      loop:
        - "{{ kafka_data_dir }}"
        - "{{ kafka_log_dir }}"
        - /var/log/kafka
        - /opt

    # ── Deploy Kafka binary ──────────────────────────────────────────
    - name: Copy Kafka binary from Tantor server
      copy:
        src: "{{ kafka_binary_local_path }}"
        dest: "/tmp/{{ kafka_binary_filename }}"

    - name: Check if Kafka already extracted
      stat:
        path: "{{ kafka_install_dir }}/bin/kafka-server-start.sh"
      register: kafka_bin

    # APB v1.2.0 #5 — extract directly INTO the per-cluster install dir
    # (NOT a symlink to a shared /opt/kafka_X.Y.Z). Two clusters on the
    # same host need two physical Kafka trees so their server.properties,
    # config/log4j2.yaml, and any other config edits don't share state.
    - name: Ensure per-cluster install dir exists
      file:
        path: "{{ kafka_install_dir }}"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"

    - name: Extract Kafka into per-cluster install dir
      unarchive:
        src: "/tmp/{{ kafka_binary_filename }}"
        dest: "{{ kafka_install_dir }}"
        remote_src: true
        extra_opts: ["--strip-components=1"]
      when: not kafka_bin.stat.exists

    - name: Set Kafka ownership
      file:
        path: "{{ kafka_install_dir }}/"
        owner: kafka
        group: kafka
        recurse: true

    - name: Clean up tarball
      file:
        path: "/tmp/{{ kafka_binary_filename }}"
        state: absent

    # ── Configure SELinux (RHEL only) ────────────────────────────────
    - name: Allow Kafka through SELinux
      command: setsebool -P domain_can_mmap_files 1
      when: ansible_os_family == "RedHat"
      ignore_errors: true

{% if has_brokers %}
# =============================================================================
# Brokers (including combined broker+controller)
# =============================================================================
- name: Configure and start Kafka brokers
  hosts: brokers:broker_controllers
  become: true
  serial: 1
  tasks:
{% if ssl_enabled %}
    # ── TLS keystore + truststore (per-host paths come from inventory) ──
    - name: Ensure SSL directory exists
      file:
        path: /etc/kafka/ssl
        state: directory
        owner: kafka
        group: kafka
        mode: "0750"

    - name: Upload broker keystore
      copy:
        src: "{{ '{{' }} broker_keystore_src {{ '}}' }}"
        dest: /etc/kafka/ssl/broker.p12
        owner: kafka
        group: kafka
        mode: "0640"

    - name: Upload truststore (PEM)
      copy:
        src: "{{ '{{' }} broker_truststore_src {{ '}}' }}"
        dest: /etc/kafka/ssl/truststore.pem
        owner: kafka
        group: kafka
        mode: "0644"
{% endif %}

    - name: Upload broker configuration
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_server.properties"
        dest: "{{ kafka_install_dir }}/config/server.properties"
        owner: kafka
        group: kafka
        mode: "0640"

    # APB v1.4.0 #5 — ship a known-good log4j2.yaml. The tarball includes
    # one but we've seen extract-time permission glitches that cause
    # broker startup to dump StatusLogger reconfiguration errors into
    # journalctl. Owning the file ourselves removes that whole class of
    # bug AND lets us pin the log layout.
    - name: Upload Tantor log4j2.yaml
      copy:
        src: "{{ log4j2_local_path }}"
        dest: "{{ kafka_install_dir }}/config/log4j2.yaml"
        owner: kafka
        group: kafka
        mode: "0640"

    - name: Mirror log4j2.yaml as tools-log4j2.yaml so kafka-storage.sh and friends emit clean output
      copy:
        src: "{{ log4j2_local_path }}"
        dest: "{{ kafka_install_dir }}/config/tools-log4j2.yaml"
        owner: kafka
        group: kafka
        mode: "0640"

    # ── Validate node_id vs meta.properties ────────────────────────
    - name: Check if meta.properties exists
      stat:
        path: "{{ kafka_data_dir }}/meta.properties"
      register: meta_props

    - name: Read existing node.id from meta.properties
      command: grep '^node.id=' {{ kafka_data_dir }}/meta.properties
      register: existing_node_id
      when: meta_props.stat.exists
      changed_when: false
      ignore_errors: true

    - name: Read configured node.id from server.properties
      command: grep '^node.id=' {{ kafka_install_dir }}/config/server.properties
      register: config_node_id
      changed_when: false

    - name: Warn on node_id mismatch — clearing old data
      debug:
        msg: >
          NODE ID MISMATCH: meta.properties has {{ '{{' }} existing_node_id.stdout | default('none') {{ '}}' }}
          but config has {{ '{{' }} config_node_id.stdout {{ '}}' }}.
          Clearing old Kafka data to resolve.
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    - name: Clear stale Kafka data on node_id mismatch
      file:
        path: "{{ kafka_data_dir }}"
        state: absent
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    - name: Recreate data directory after cleanup
      file:
        path: "{{ kafka_data_dir }}"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    # ── Upload systemd unit with JAVA_HOME ─────────────────────────
    # Per-cluster unit name (APB v1.2.0 #5) so two clusters on the same
    # host don't fight over /etc/systemd/system/kafka.service.
    - name: Upload systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_kafka.service"
        dest: /etc/systemd/system/{{ kafka_unit_name }}
        mode: "0644"

    - name: Reload systemd
      systemd:
        daemon_reload: true

{% if cluster_mode == "kraft" %}
    - name: Format KRaft storage
      command: >
        {{ kafka_install_dir }}/bin/kafka-storage.sh format
        --cluster-id {{ cluster_uuid }}
        -c {{ kafka_install_dir }}/config/server.properties
        --ignore-formatted
      become_user: kafka
      environment:
        JAVA_HOME: "{{ '{{' }} discovered_java_home {{ '}}' }}"
        # APB v1.4.0 #5 — point CLI tools at the tools-log4j2.yaml we ship
        # so kafka-storage.sh format doesn't print "ERROR StatusLogger
        # No log4j2 configuration file found" during deploy.
        KAFKA_LOG4J_OPTS: "-Dlog4j2.configurationFile=file:{{ kafka_install_dir }}/config/tools-log4j2.yaml"
{% endif %}

    - name: Enable and start Kafka
      systemd:
        name: "{{ kafka_unit_name }}"
        enabled: true
        state: started

    # Cold JVM + KRaft metadata replay can take >60s on small VMs. Give it
    # real headroom AND fail-fast if systemd already reports the unit failed
    # so the operator gets a useful error instead of a 60s timeout silence.
    # If we DO time out, attach the last 80 lines of journalctl so the
    # deploy task logs (and thus the UI Deploy Progress panel) tell the
    # operator exactly why Kafka didn't come up.
    - name: Sleep briefly so systemd can transition the unit
      pause: { seconds: 2 }

    - name: Pre-check — bail early if Kafka unit already failed
      command: systemctl is-failed {{ kafka_unit_name }}
      register: kafka_prefail
      changed_when: false
      failed_when: false

    - name: Capture journalctl when systemd reports kafka failed
      command: journalctl -u {{ kafka_unit_name }} --no-pager -n 80
      register: kafka_early_journal
      changed_when: false
      when: kafka_prefail.stdout == 'failed'

    - name: Surface kafka early-failure log
      fail:
        msg: |
          {{ kafka_unit_name }} failed to start. Last 80 lines of journalctl:

          {{ '{{' }} kafka_early_journal.stdout {{ '}}' }}
      when: kafka_prefail.stdout == 'failed'

    - name: Wait for Kafka to start listening
      wait_for:
        port: {{ cluster_config.get('listener_port', 9092) }}
        host: "{{ '{{' }} ansible_host {{ '}}' }}"
        timeout: 180
        delay: 5
      register: kafka_port_wait
      ignore_errors: true

    - name: Capture journalctl on port-wait timeout
      command: journalctl -u {{ kafka_unit_name }} --no-pager -n 80
      register: kafka_late_journal
      changed_when: false
      when: kafka_port_wait is failed

    - name: Capture systemctl status on port-wait timeout
      command: systemctl status {{ kafka_unit_name }} --no-pager -l
      register: kafka_late_status
      changed_when: false
      when: kafka_port_wait is failed

    - name: Fail with full diagnostic when Kafka never bound the port
      fail:
        msg: |
          Kafka did not start listening on port {{ cluster_config.get('listener_port', 9092) }}
          within 180s on host {{ '{{' }} ansible_host {{ '}}' }}.

          systemctl status kafka:
          {{ '{{' }} kafka_late_status.stdout {{ '}}' }}

          Last 80 lines of journalctl -u kafka:
          {{ '{{' }} kafka_late_journal.stdout {{ '}}' }}

          Common causes:
            - firewalld blocking the listener port (run: firewall-cmd --add-port={{ cluster_config.get('listener_port', 9092) }}/tcp --permanent && firewall-cmd --reload)
            - SELinux denying bind (audit2allow on /var/log/audit/audit.log)
            - advertised.listeners pointing at an IP this host can't bind
            - /var/lib/kafka/data permissions wrong (chown -R kafka:kafka)
            - Stale meta.properties from a previous cluster (rm -rf /var/lib/kafka/data/* and re-deploy)
      when: kafka_port_wait is failed

    - name: Verify Kafka process is running
      command: systemctl is-active {{ kafka_unit_name }}
      register: kafka_status
      changed_when: false
      failed_when: kafka_status.stdout != "active"
{% endif %}

{% if has_controllers %}
# =============================================================================
# Standalone KRaft Controllers
# =============================================================================
- name: Configure and start KRaft controllers
  hosts: controllers
  become: true
  serial: 1
  tasks:
    - name: Upload controller configuration
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_server.properties"
        dest: "{{ kafka_install_dir }}/config/server.properties"
        owner: kafka
        group: kafka
        mode: "0644"

    # ── Validate node_id vs meta.properties ────────────────────────
    - name: Check if meta.properties exists
      stat:
        path: "{{ kafka_data_dir }}/meta.properties"
      register: meta_props

    - name: Read existing node.id from meta.properties
      command: grep '^node.id=' {{ kafka_data_dir }}/meta.properties
      register: existing_node_id
      when: meta_props.stat.exists
      changed_when: false
      ignore_errors: true

    - name: Read configured node.id from server.properties
      command: grep '^node.id=' {{ kafka_install_dir }}/config/server.properties
      register: config_node_id
      changed_when: false

    - name: Clear stale data on node_id mismatch
      file:
        path: "{{ kafka_data_dir }}"
        state: absent
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    - name: Recreate data directory after cleanup
      file:
        path: "{{ kafka_data_dir }}"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    - name: Upload systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_kafka-kraft-controller.service"
        dest: /etc/systemd/system/kafka-kraft-controller.service
        mode: "0644"

    - name: Reload systemd
      systemd:
        daemon_reload: true

    - name: Format KRaft storage
      command: >
        {{ kafka_install_dir }}/bin/kafka-storage.sh format
        --cluster-id {{ cluster_uuid }}
        -c {{ kafka_install_dir }}/config/server.properties
        --ignore-formatted
      become_user: kafka
      environment:
        JAVA_HOME: "{{ '{{' }} discovered_java_home {{ '}}' }}"

    - name: Enable and start controller
      systemd:
        name: kafka-kraft-controller
        enabled: true
        state: started

    - name: Wait for controller to start listening
      wait_for:
        port: {{ cluster_config.get('controller_port', 9093) }}
        host: "{{ '{{' }} ansible_host {{ '}}' }}"
        timeout: 60
        delay: 5

    - name: Verify controller process is running
      command: systemctl is-active kafka-kraft-controller
      register: ctrl_status
      changed_when: false
      failed_when: ctrl_status.stdout != "active"
{% endif %}

{% if has_ksqldb %}
# =============================================================================
# ksqlDB
# =============================================================================
- name: Install and start ksqlDB
  hosts: ksqldbs
  become: true
  tasks:
    - name: Check if ksqlDB already installed
      stat:
        path: "{{ ksqldb_install_dir }}/bin/ksql-server-start"
      register: ksqldb_bin

    - name: Copy ksqlDB binary from Tantor server
      copy:
        src: "{{ ksqldb_binary_local_path }}"
        dest: "/tmp/{{ ksqldb_binary_filename }}"
      when: not ksqldb_bin.stat.exists

    - name: Create ksqlDB install directory
      file:
        path: "{{ ksqldb_install_dir }}"
        state: directory
        owner: kafka
        group: kafka
      when: not ksqldb_bin.stat.exists

    - name: Extract ksqlDB
      shell: "tar xzf /tmp/{{ ksqldb_binary_filename }} -C {{ ksqldb_install_dir }} --strip-components=1"
      when: not ksqldb_bin.stat.exists

    - name: Set ksqlDB ownership
      file:
        path: "{{ ksqldb_install_dir }}"
        owner: kafka
        group: kafka
        recurse: true

    - name: Clean up ksqlDB tarball
      file:
        path: "/tmp/{{ ksqldb_binary_filename }}"
        state: absent

    - name: Create ksqlDB config directory
      file:
        path: "{{ ksqldb_install_dir }}/config"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"

    - name: Upload ksqlDB configuration
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_ksql-server.properties"
        dest: "{{ ksqldb_install_dir }}/config/ksql-server.properties"
        owner: kafka
        group: kafka
        mode: "0644"

    - name: Upload systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_ksqldb.service"
        dest: /etc/systemd/system/ksqldb.service
        mode: "0644"

    - name: Reload and start ksqlDB
      systemd:
        name: ksqldb
        daemon_reload: true
        enabled: true
        state: started
{% endif %}

{% if has_connect %}
# =============================================================================
# Kafka Connect
# =============================================================================
- name: Configure and start Kafka Connect
  hosts: kafka_connects
  become: true
  tasks:
    - name: Create plugins directory
      file:
        path: "{{ kafka_install_dir }}/plugins"
        state: directory
        owner: kafka
        group: kafka

    - name: Upload Connect configuration
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_connect-distributed.properties"
        dest: "{{ kafka_install_dir }}/config/connect-distributed.properties"
        owner: kafka
        group: kafka
        mode: "0644"

    - name: Upload systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_kafka-connect.service"
        dest: /etc/systemd/system/kafka-connect.service
        mode: "0644"

    - name: Reload and start Connect
      systemd:
        name: kafka-connect
        daemon_reload: true
        enabled: true
        state: started
{% endif %}

{% if has_schema_registry %}
- name: Install and start Apicurio Schema Registry
  hosts: schema_registrys
  become: true
  tasks:
    - name: Create apicurio user
      user:
        name: apicurio
        system: true
        home: "{{ apicurio_install_dir }}"
        shell: /bin/false
        create_home: false

    - name: Create Apicurio install directory
      file:
        path: "{{ apicurio_install_dir }}"
        state: directory
        owner: apicurio
        group: apicurio
        mode: "0755"

    - name: Copy Apicurio binary to host
      copy:
        src: "{{ apicurio_binary_local_path }}"
        dest: /tmp/{{ apicurio_binary_filename }}
        mode: "0644"

    - name: Extract Apicurio (strip {{ apicurio_strip_components }} component(s))
      unarchive:
        src: /tmp/{{ apicurio_binary_filename }}
        dest: "{{ apicurio_install_dir }}"
        remote_src: yes
        extra_opts:
          - "--strip-components={{ apicurio_strip_components }}"
        owner: apicurio
        group: apicurio

    - name: Place application.properties
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_apicurio.properties"
        dest: "{{ apicurio_install_dir }}/application.properties"
        owner: apicurio
        group: apicurio
        mode: "0644"

    - name: Install schema-registry systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_schema-registry.service"
        dest: /etc/systemd/system/schema-registry.service
        mode: "0644"

    - name: Reload and start Schema Registry
      systemd:
        name: schema-registry
        daemon_reload: true
        enabled: true
        state: started

    - name: Wait for Schema Registry to be reachable
      wait_for:
        port: {{ cluster_config.get('schema_registry_port', 8085) }}
        host: "{{ '{{' }} ansible_host {{ '}}' }}"
        timeout: 90
        delay: 5

    - name: Clean up tarball
      file:
        path: /tmp/{{ apicurio_binary_filename }}
        state: absent
{% endif %}
