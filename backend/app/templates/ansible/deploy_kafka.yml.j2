---
# =============================================================================
# Tantor Kafka Deployment Playbook (Production-Ready)
# - Validates Java, discovers JAVA_HOME
# - Cleans stale services before deploying
# - Validates meta.properties node_id consistency
# - Health checks after each service start
# =============================================================================

- name: Prepare Kafka on all hosts
  hosts: all
  become: true
  tasks:
    - name: Gather OS facts
      setup:
        gather_subset:
          - '!all'
          - 'os_family'
          - 'distribution'
          - 'distribution_major_version'

    # ── Java Installation ──────────────────────────────────────────────
    - name: Install Java (Debian/Ubuntu)
      apt:
        name: openjdk-17-jre-headless
        state: present
        update_cache: true
      when: ansible_os_family == "Debian"

    - name: Install Java (RHEL/Rocky/CentOS)
      dnf:
        name: java-17-openjdk-headless
        state: present
      when: ansible_os_family == "RedHat"

    # ── Discover real JAVA_HOME (critical: don't trust env vars) ─────
    - name: Find java binary path
      command: which java
      register: java_which
      changed_when: false

    - name: Resolve java symlink to real path
      command: readlink -f {{ '{{' }} java_which.stdout {{ '}}' }}
      register: java_real
      changed_when: false

    - name: Set JAVA_HOME fact
      set_fact:
        discovered_java_home: "{{ '{{' }} java_real.stdout | regex_replace('/bin/java$', '') {{ '}}' }}"

    - name: Validate Java works
      command: "{{ '{{' }} discovered_java_home {{ '}}' }}/bin/java -version"
      register: java_ver
      changed_when: false
      failed_when: java_ver.rc != 0

    - name: Display Java info
      debug:
        msg: "JAVA_HOME={{ '{{' }} discovered_java_home {{ '}}' }} | {{ '{{' }} java_ver.stderr_lines[0] | default('unknown') {{ '}}' }}"

    - name: Fix /etc/profile.d/java.sh
      copy:
        content: |
          export JAVA_HOME={{ '{{' }} discovered_java_home {{ '}}' }}
          export PATH=$JAVA_HOME/bin:$PATH
        dest: /etc/profile.d/java.sh
        mode: "0644"

    # ── Cleanup stale Kafka services ─────────────────────────────────
    - name: Find all existing kafka systemd units
      find:
        paths: /etc/systemd/system
        patterns: "kafka*.service"
      register: existing_kafka_services

    - name: Stop and disable stale Kafka services
      systemd:
        name: "{{ '{{' }} item.path | basename {{ '}}' }}"
        state: stopped
        enabled: false
      loop: "{{ '{{' }} existing_kafka_services.files {{ '}}' }}"
      ignore_errors: true

    - name: Remove stale Kafka service files
      file:
        path: "{{ '{{' }} item.path {{ '}}' }}"
        state: absent
      loop: "{{ '{{' }} existing_kafka_services.files {{ '}}' }}"

    - name: Reload systemd after cleanup
      systemd:
        daemon_reload: true

    # ── Create user and directories ──────────────────────────────────
    - name: Create kafka group
      group:
        name: kafka
        system: true

    - name: Create kafka user
      user:
        name: kafka
        group: kafka
        system: true
        shell: /bin/false
        create_home: true
        home: /home/kafka

    - name: Create required directories
      file:
        path: "{{ '{{' }} item {{ '}}' }}"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"
      loop:
        - "{{ kafka_data_dir }}"
        - "{{ kafka_log_dir }}"
        - /var/log/kafka
        - /opt

    # ── Deploy Kafka binary ──────────────────────────────────────────
    - name: Copy Kafka binary from Tantor server
      copy:
        src: "{{ kafka_binary_local_path }}"
        dest: "/tmp/{{ kafka_binary_filename }}"

    - name: Check if Kafka already extracted
      stat:
        path: "{{ kafka_install_dir }}/bin/kafka-server-start.sh"
      register: kafka_bin

    - name: Extract Kafka
      unarchive:
        src: "/tmp/{{ kafka_binary_filename }}"
        dest: /opt/
        remote_src: true
      when: not kafka_bin.stat.exists

    - name: Symlink Kafka home
      file:
        src: "/opt/{{ kafka_binary_filename | replace('.tgz', '') }}"
        dest: "{{ kafka_install_dir }}"
        state: link
        force: true

    - name: Set Kafka ownership
      file:
        path: "{{ kafka_install_dir }}/"
        owner: kafka
        group: kafka
        recurse: true

    - name: Clean up tarball
      file:
        path: "/tmp/{{ kafka_binary_filename }}"
        state: absent

    # ── Configure SELinux (RHEL only) ────────────────────────────────
    - name: Allow Kafka through SELinux
      command: setsebool -P domain_can_mmap_files 1
      when: ansible_os_family == "RedHat"
      ignore_errors: true

{% if has_brokers %}
# =============================================================================
# Brokers (including combined broker+controller)
# =============================================================================
- name: Configure and start Kafka brokers
  hosts: brokers:broker_controllers
  become: true
  serial: 1
  tasks:
{% if ssl_enabled %}
    # ── TLS keystore + truststore (per-host paths come from inventory) ──
    - name: Ensure SSL directory exists
      file:
        path: /etc/kafka/ssl
        state: directory
        owner: kafka
        group: kafka
        mode: "0750"

    - name: Upload broker keystore
      copy:
        src: "{{ '{{' }} broker_keystore_src {{ '}}' }}"
        dest: /etc/kafka/ssl/broker.p12
        owner: kafka
        group: kafka
        mode: "0640"

    - name: Upload truststore (PEM)
      copy:
        src: "{{ '{{' }} broker_truststore_src {{ '}}' }}"
        dest: /etc/kafka/ssl/truststore.pem
        owner: kafka
        group: kafka
        mode: "0644"
{% endif %}

    - name: Upload broker configuration
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_server.properties"
        dest: "{{ kafka_install_dir }}/config/server.properties"
        owner: kafka
        group: kafka
        mode: "0640"

    # ── Validate node_id vs meta.properties ────────────────────────
    - name: Check if meta.properties exists
      stat:
        path: "{{ kafka_data_dir }}/meta.properties"
      register: meta_props

    - name: Read existing node.id from meta.properties
      command: grep '^node.id=' {{ kafka_data_dir }}/meta.properties
      register: existing_node_id
      when: meta_props.stat.exists
      changed_when: false
      ignore_errors: true

    - name: Read configured node.id from server.properties
      command: grep '^node.id=' {{ kafka_install_dir }}/config/server.properties
      register: config_node_id
      changed_when: false

    - name: Warn on node_id mismatch — clearing old data
      debug:
        msg: >
          NODE ID MISMATCH: meta.properties has {{ '{{' }} existing_node_id.stdout | default('none') {{ '}}' }}
          but config has {{ '{{' }} config_node_id.stdout {{ '}}' }}.
          Clearing old Kafka data to resolve.
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    - name: Clear stale Kafka data on node_id mismatch
      file:
        path: "{{ kafka_data_dir }}"
        state: absent
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    - name: Recreate data directory after cleanup
      file:
        path: "{{ kafka_data_dir }}"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    # ── Upload systemd unit with JAVA_HOME ─────────────────────────
    - name: Upload systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_kafka.service"
        dest: /etc/systemd/system/kafka.service
        mode: "0644"

    - name: Reload systemd
      systemd:
        daemon_reload: true

{% if cluster_mode == "kraft" %}
    - name: Format KRaft storage
      command: >
        {{ kafka_install_dir }}/bin/kafka-storage.sh format
        --cluster-id {{ cluster_uuid }}
        -c {{ kafka_install_dir }}/config/server.properties
        --ignore-formatted
      become_user: kafka
      environment:
        JAVA_HOME: "{{ '{{' }} discovered_java_home {{ '}}' }}"
{% endif %}

    - name: Enable and start Kafka
      systemd:
        name: kafka
        enabled: true
        state: started

    # ── Health check: wait for Kafka to be ready ───────────────────
    - name: Wait for Kafka to start listening
      wait_for:
        port: {{ cluster_config.get('listener_port', 9092) }}
        host: "{{ '{{' }} ansible_host {{ '}}' }}"
        timeout: 60
        delay: 5

    - name: Verify Kafka process is running
      command: systemctl is-active kafka
      register: kafka_status
      changed_when: false
      failed_when: kafka_status.stdout != "active"
{% endif %}

{% if has_controllers %}
# =============================================================================
# Standalone KRaft Controllers
# =============================================================================
- name: Configure and start KRaft controllers
  hosts: controllers
  become: true
  serial: 1
  tasks:
    - name: Upload controller configuration
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_server.properties"
        dest: "{{ kafka_install_dir }}/config/server.properties"
        owner: kafka
        group: kafka
        mode: "0644"

    # ── Validate node_id vs meta.properties ────────────────────────
    - name: Check if meta.properties exists
      stat:
        path: "{{ kafka_data_dir }}/meta.properties"
      register: meta_props

    - name: Read existing node.id from meta.properties
      command: grep '^node.id=' {{ kafka_data_dir }}/meta.properties
      register: existing_node_id
      when: meta_props.stat.exists
      changed_when: false
      ignore_errors: true

    - name: Read configured node.id from server.properties
      command: grep '^node.id=' {{ kafka_install_dir }}/config/server.properties
      register: config_node_id
      changed_when: false

    - name: Clear stale data on node_id mismatch
      file:
        path: "{{ kafka_data_dir }}"
        state: absent
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    - name: Recreate data directory after cleanup
      file:
        path: "{{ kafka_data_dir }}"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"
      when:
        - meta_props.stat.exists
        - existing_node_id.stdout is defined
        - existing_node_id.stdout != config_node_id.stdout

    - name: Upload systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_kafka-kraft-controller.service"
        dest: /etc/systemd/system/kafka-kraft-controller.service
        mode: "0644"

    - name: Reload systemd
      systemd:
        daemon_reload: true

    - name: Format KRaft storage
      command: >
        {{ kafka_install_dir }}/bin/kafka-storage.sh format
        --cluster-id {{ cluster_uuid }}
        -c {{ kafka_install_dir }}/config/server.properties
        --ignore-formatted
      become_user: kafka
      environment:
        JAVA_HOME: "{{ '{{' }} discovered_java_home {{ '}}' }}"

    - name: Enable and start controller
      systemd:
        name: kafka-kraft-controller
        enabled: true
        state: started

    - name: Wait for controller to start listening
      wait_for:
        port: {{ cluster_config.get('controller_port', 9093) }}
        host: "{{ '{{' }} ansible_host {{ '}}' }}"
        timeout: 60
        delay: 5

    - name: Verify controller process is running
      command: systemctl is-active kafka-kraft-controller
      register: ctrl_status
      changed_when: false
      failed_when: ctrl_status.stdout != "active"
{% endif %}

{% if has_ksqldb %}
# =============================================================================
# ksqlDB
# =============================================================================
- name: Install and start ksqlDB
  hosts: ksqldbs
  become: true
  tasks:
    - name: Check if ksqlDB already installed
      stat:
        path: "{{ ksqldb_install_dir }}/bin/ksql-server-start"
      register: ksqldb_bin

    - name: Copy ksqlDB binary from Tantor server
      copy:
        src: "{{ ksqldb_binary_local_path }}"
        dest: "/tmp/{{ ksqldb_binary_filename }}"
      when: not ksqldb_bin.stat.exists

    - name: Create ksqlDB install directory
      file:
        path: "{{ ksqldb_install_dir }}"
        state: directory
        owner: kafka
        group: kafka
      when: not ksqldb_bin.stat.exists

    - name: Extract ksqlDB
      shell: "tar xzf /tmp/{{ ksqldb_binary_filename }} -C {{ ksqldb_install_dir }} --strip-components=1"
      when: not ksqldb_bin.stat.exists

    - name: Set ksqlDB ownership
      file:
        path: "{{ ksqldb_install_dir }}"
        owner: kafka
        group: kafka
        recurse: true

    - name: Clean up ksqlDB tarball
      file:
        path: "/tmp/{{ ksqldb_binary_filename }}"
        state: absent

    - name: Create ksqlDB config directory
      file:
        path: "{{ ksqldb_install_dir }}/config"
        state: directory
        owner: kafka
        group: kafka
        mode: "0755"

    - name: Upload ksqlDB configuration
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_ksql-server.properties"
        dest: "{{ ksqldb_install_dir }}/config/ksql-server.properties"
        owner: kafka
        group: kafka
        mode: "0644"

    - name: Upload systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_ksqldb.service"
        dest: /etc/systemd/system/ksqldb.service
        mode: "0644"

    - name: Reload and start ksqlDB
      systemd:
        name: ksqldb
        daemon_reload: true
        enabled: true
        state: started
{% endif %}

{% if has_connect %}
# =============================================================================
# Kafka Connect
# =============================================================================
- name: Configure and start Kafka Connect
  hosts: kafka_connects
  become: true
  tasks:
    - name: Create plugins directory
      file:
        path: "{{ kafka_install_dir }}/plugins"
        state: directory
        owner: kafka
        group: kafka

    - name: Upload Connect configuration
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_connect-distributed.properties"
        dest: "{{ kafka_install_dir }}/config/connect-distributed.properties"
        owner: kafka
        group: kafka
        mode: "0644"

    - name: Upload systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_kafka-connect.service"
        dest: /etc/systemd/system/kafka-connect.service
        mode: "0644"

    - name: Reload and start Connect
      systemd:
        name: kafka-connect
        daemon_reload: true
        enabled: true
        state: started
{% endif %}

{% if has_schema_registry %}
- name: Install and start Apicurio Schema Registry
  hosts: schema_registrys
  become: true
  tasks:
    - name: Create apicurio user
      user:
        name: apicurio
        system: true
        home: "{{ apicurio_install_dir }}"
        shell: /bin/false
        create_home: false

    - name: Create Apicurio install directory
      file:
        path: "{{ apicurio_install_dir }}"
        state: directory
        owner: apicurio
        group: apicurio
        mode: "0755"

    - name: Copy Apicurio binary to host
      copy:
        src: "{{ apicurio_binary_local_path }}"
        dest: /tmp/{{ apicurio_binary_filename }}
        mode: "0644"

    - name: Extract Apicurio (strip {{ apicurio_strip_components }} component(s))
      unarchive:
        src: /tmp/{{ apicurio_binary_filename }}
        dest: "{{ apicurio_install_dir }}"
        remote_src: yes
        extra_opts:
          - "--strip-components={{ apicurio_strip_components }}"
        owner: apicurio
        group: apicurio

    - name: Place application.properties
      copy:
        src: "{{ configs_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_apicurio.properties"
        dest: "{{ apicurio_install_dir }}/application.properties"
        owner: apicurio
        group: apicurio
        mode: "0644"

    - name: Install schema-registry systemd unit
      copy:
        src: "{{ systemd_dir }}/{{ '{{' }} ansible_host {{ '}}' }}_{{ '{{' }} node_id {{ '}}' }}_schema-registry.service"
        dest: /etc/systemd/system/schema-registry.service
        mode: "0644"

    - name: Reload and start Schema Registry
      systemd:
        name: schema-registry
        daemon_reload: true
        enabled: true
        state: started

    - name: Wait for Schema Registry to be reachable
      wait_for:
        port: {{ cluster_config.get('schema_registry_port', 8085) }}
        host: "{{ '{{' }} ansible_host {{ '}}' }}"
        timeout: 90
        delay: 5

    - name: Clean up tarball
      file:
        path: /tmp/{{ apicurio_binary_filename }}
        state: absent
{% endif %}
